# Nexus environment configuration template
# Copy to ~/.nexus/.env and fill in your API keys.
# None of these values are required for local-only mode (Overpass + Open-Meteo + OSRM are all free, no key needed).

# Yelp Fusion API — restaurant search and menu data
# Get a key at: https://docs.developer.yelp.com/docs/fusion-intro
YELP_API_KEY=

# Hiking Project API — curated trail database (optional, Overpass covers all trails)
# Get a key at: https://www.hikingproject.com/data
HIKING_PROJECT_KEY=
